// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentVisibility {
  private
  public
}

enum IngestionStatus {
  pending
  processing
  ready
  failed
}

enum SourceType {
  pdf
  markdown
  txt
  html
  rtf
}

model Document {
  id          String             @id @default(uuid())
  userId      String
  title       String
  contentHash String
  rawText     String?
  sourceType  SourceType
  visibility  DocumentVisibility @default(private)
  status      IngestionStatus    @default(pending)
  isActive    Boolean            @default(true)
  version     Int                @default(1)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  chunks Chunk[]

  @@unique([userId, contentHash])
  @@map("documents")
}

model Chunk {
  id                String   @id @default(uuid())
  documentId        String
  content           String
  contentHash       String
  chunkIndex        Int
  embeddingProvider String   @default("gemini-embedding-001")
  embedding         Unsupported("vector(768)")
  createdAt         DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, contentHash])
  @@index([documentId])
  @@map("chunks")
}

enum RiskTier {
  read
  internal_write
  external_write
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id            String   @id @default(uuid())
  userId        String
  content       String
  sourceQueryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("notes")
}

model Task {
  id            String    @id @default(uuid())
  userId        String
  title         String
  description   String?
  dueAt         DateTime?
  done          Boolean   @default(false)
  sourceQueryId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("tasks")
}

model ToolCallAudit {
  id        String   @id @default(uuid())
  userId    String
  toolName  String
  riskTier  RiskTier
  params    Json
  result    Json?
  confirmed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@map("tool_call_audits")
}

model QueryTrace {
  id               String   @id @default(uuid())
  userId           String
  query            String
  retrievedChunks  Json
  provider         String
  model            String
  latencyBreakdown Json
  cacheFlags       Json
  toolCallAuditIds String[]
  createdAt        DateTime @default(now())

  @@map("query_traces")
}
