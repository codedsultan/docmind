# ── Server ──────────────────────────────────────────────────────
PORT=4500
API_PREFIX=api
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────
# Browser origin allowed to call the API
CORS_ORIGIN=http://localhost:3400

# ── Database (Postgres) ─────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5349
PG_DATABASE=docmind
PG_USER=docmind
PG_PASSWORD=docmind
PG_SSL=false
DATABASE_URL=postgresql://docmind:docmind@localhost:5349/docmind

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6399
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6399

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
API_KEY=dev-api-key-change-in-production
INTERNAL_API_KEY=change_me_in_production

# ── Queues (BullMQ) ─────────────────────────────────────────────
QUEUE_DEFAULT=default
QUEUE_MAIL=mail
QUEUE_NOTIFICATIONS=notifications
QUEUE_INGESTION=ingestion
WORKER_CONCURRENCY=5

# ── AI Providers ─────────────────────────────────────────────────
# Gemini API key — required for embeddings (gemini-embedding-001, 768d)
GEMINI_API_KEY=your_gemini_api_key_here
# Generation provider: gemini (default) | groq
PROVIDER=gemini
# Generation model: gemini-2.0-flash (default), gemini-1.5-pro
GENERATION_MODEL=gemini-2.0-flash
EMBEDDING_DIM=768

# Groq API key — required only when PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
# Groq model override (default: llama3-8b-8192)
GROQ_MODEL=llama3-8b-8192


