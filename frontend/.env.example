# ── Public API URL (baked into the JS bundle at build time) ─────
# Must be a URL the BROWSER can reach.
# Local dev: http://localhost:4500/api
# Production: https://docmind.xurl.fyi/api
NEXT_PUBLIC_API_URL=http://localhost:4500/api

# ── Server-side API URL (read at runtime, never sent to browser) ─
# Points directly at the api container over the internal Docker network.
# In local dev without Docker, this can match NEXT_PUBLIC_API_URL.
# In production Docker: http://docmind-staging-api:4500/api
API_BASE_URL_SERVER=http://localhost:4500/api

# ── Auth ────────────────────────────────────────────────────────
# Must match backend API_KEY env. Docker compose sets this via build arg.
NEXT_PUBLIC_API_KEY=dev-api-key-change-in-production

# ── App ─────────────────────────────────────────────────────────
PORT=3400
NODE_ENV=development
